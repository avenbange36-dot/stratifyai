APP_NAME=StratifyAI Enterprise
APP_ENV=development
SECRET_KEY=change-this-to-a-long-random-secret
DATABASE_URL=sqlite:///./stratifyai.db
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Stripe. Keep demo mode true until your live Stripe account is ready.
DEMO_PAYMENT_MODE=true
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Optional OpenAI-compatible LLM configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Enterprise SSO placeholders. Configure through your IdP before production.
SAML_ENTITY_ID=
SAML_SSO_URL=
SAML_X509_CERT=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_ISSUER_URL=

# Security/ops
SECURE_COOKIES=false
RATE_LIMIT_PER_MINUTE=120
AUDIT_LOG_RETENTION_DAYS=365
SUPPORT_EMAIL=support@yourdomain.com
